# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local env files
.env.local
.env.development.local
.env.test.local
.env.production.local

# vercel
.vercel

# typescript
*.tsbuildinfo

# Seed wallet data — never commit
sdk/wallets.jsonl
sdk/*.jsonl
*.jsonl

# Python
__pycache__/
*.pyc

# SQLite
*.db
*.sqlite

# Foundry (contracts are local-only; not built by Vercel)
contracts/out/
contracts/cache/
contracts/lib/
contracts/broadcast/

# Backups
app.backup/
